{
  "name": "vibe-flow",
  "displayName": "Vibe Flow - Code Flow Mapper",
  "description": "AI-powered code flow analysis across multiple languages with static analysis, change diff, and runtime trace mapping",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibe-flow.showProjectDiagram",
        "title": "Vibe Flow: Show Project Dependency Diagram"
      },
      {
        "command": "vibe-flow.showFunctionCallGraph",
        "title": "Vibe Flow: Show Function Call Graph"
      },
      {
        "command": "vibe-flow.helloWorld",
        "title": "Vibe Flow: Hello World"
      },
      {
        "command": "vibe-flow.analyzeStatic",
        "title": "Code Flow Mapper: Analyze Static Call Graph"
      },
      {
        "command": "vibe-flow.analyzeChangeDiff",
        "title": "Code Flow Mapper: Analyze Changes (Diff)"
      },
      {
        "command": "vibe-flow.analyzeRuntime",
        "title": "Code Flow Mapper: Analyze Runtime Trace"
      },
      {
        "command": "vibe-flow.analyzeCustom",
        "title": "Code Flow Mapper: Analyze with Custom Input"
      },
      {
        "command": "vibe-flow.startAutoCapture",
        "title": "Vibe Flow: Start Auto-Capture Runtime Flow"
      },
      {
        "command": "vibe-flow.stopAutoCapture",
        "title": "Vibe Flow: Stop Auto-Capture and Analyze"
      },
      {
        "command": "vibe-flow.captureCurrentDebug",
        "title": "Vibe Flow: Capture Current Debug Session"
      },
      {
        "command": "vibe-flow.showFlowDiagram",
        "title": "Vibe Flow: Show Flow Diagram"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  }
}

